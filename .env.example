# ============================================================
# TradePulse Backend — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# SERVER
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://tradepulse.app

# DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/tradepulse
DB_POOL_MIN=2
DB_POOL_MAX=20

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_change_this_now
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_also_min_64_chars_change_this
JWT_REFRESH_EXPIRES_IN=30d

# GOOGLE OAUTH
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ANTHROPIC AI
ANTHROPIC_API_KEY=sk-ant-your-key-here

# TRON / USDT TRC20
# Main wallet that receives all funds (your business wallet)
TRON_MAIN_WALLET=TYour_Main_Tron_Wallet_Address
TRON_MAIN_PRIVATE_KEY=your_main_private_key_keep_secret
TRON_FULL_NODE=https://api.trongrid.io
TRON_EVENT_SERVER=https://api.trongrid.io
TRON_API_KEY=your_trongrid_api_key
# USDT TRC20 contract address (mainnet)
USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
# How many USDT for pro plan
PRO_PLAN_PRICE_USDT=10
# Minutes before payment address expires
PAYMENT_EXPIRY_MINUTES=30
# Encryption key for private keys stored in DB (32 chars)
ENCRYPTION_KEY=your_32_char_encryption_key_here!!

# EMAIL (Nodemailer)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key
EMAIL_FROM=TradePulse <noreply@tradepulse.app>

# REDIS (for Bull queues)
REDIS_URL=redis://localhost:6379

# FILE UPLOADS (Cloudflare R2 / S3-compatible)
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_BUCKET=tradepulse-uploads
S3_ACCESS_KEY=your_r2_access_key
S3_SECRET_KEY=your_r2_secret_key
S3_REGION=auto
CDN_URL=https://cdn.tradepulse.app

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# 2FA
TWO_FA_APP_NAME=TradePulse
